PORT=5000
NODE_ENV=development
# Local: postgresql://USER:PASSWORD@localhost:5432/viral_market
# Render: copy the "Internal Database URL" from your Render Postgres dashboard
DATABASE_URL=

# Auth — use long random strings in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
